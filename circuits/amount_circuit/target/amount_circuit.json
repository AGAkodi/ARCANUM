{"noir_version":"1.0.0-beta.22+c57152f91260ecdb9faad4efc20abb14b6d2ece7","hash":"16907636351721605942","abi":{"parameters":[{"name":"amount","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"balance","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"min_amount","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"}],"return_type":null,"error_types":{}},"bytecode":"","debug_symbols":"nZHBCoMwDIbfJece1OqmvsoYUjVKoVSp7WCI775YrNPDYHhJmvz9kqaZocXa9ZXU3TBB+ZihNlIp2VdqaISVg6bsvDAIYWUNIqXgoBM1CoPaQqmdUgxeQjl/aRqF9t4KQ2rEAHVLngp2UuF6WtiXjn6jPIo3mCfxjmfxv3xSpDufXOA5zwKfXeKTfOf5iX9SJBppTj8OHEoaOPU28/ZGQzC4UwEGubeFt3EEZbqsnY0UtcJtYZ3TzWF/9j0GJWx4NEODrTO4dvYaveUD","file_map":{"51":{"source":"// Amount range proof.\n//\n// Proves the payment amount is at least min_amount and does not exceed\n// the sender's balance. Neither the amount nor the balance is revealed;\n// only min_amount (the policy floor, normally 1) is public.\nfn main(amount: u64, balance: u64, min_amount: pub u64) {\n    assert(amount >= min_amount);\n    assert(amount <= balance);\n}\n\n#[test]\nfn test_valid_amount_passes() {\n    main(5000, 10000, 1);\n}\n\n#[test(should_fail)]\nfn test_amount_exceeding_balance_fails() {\n    main(15000, 10000, 1);\n}\n\n#[test(should_fail)]\nfn test_zero_amount_fails() {\n    main(0, 10000, 1);\n}\n","path":"/Users/odeyalexander/Desktop/current/Web/ZBank/circuits/amount_circuit/src/main.nr","function_locations":[{"start":288,"name":"main"},{"start":396,"name":"test_valid_amount_passes"},{"start":489,"name":"test_amount_exceeding_balance_fails"},{"start":570,"name":"test_zero_amount_fails"}]}}}